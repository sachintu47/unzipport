UNZIP_VERSION="6.0"
UNZIP_VERSION_SHORT=$(echo $UNZIP_VERSION | tr -d '.')

# bump: debian-version /DEBIAN_VERSION="(.*)"/ https://deb.debian.org/debian/pool/main/u/unzip/|re:/unzip_6\.0-(\d+)\.debian\.tar\.xz/|semver:*
DEBIAN_VERSION="29"

export ZOPEN_BUILD_LINE="STABLE"
export ZOPEN_CATEGORIES="compression"
export ZOPEN_STABLE_URL="https://sourceforge.net/projects/infozip/files/UnZip%206.x%20%28latest%29/UnZip%20${UNZIP_VERSION}/unzip${UNZIP_VERSION_SHORT}.tar.gz"
export ZOPEN_STABLE_DEPS="make zoslib zip zedc_ascii patch xz"
export ZOPEN_DEV_URL="https://github.com/LuaDist/unzip.git"
export ZOPEN_DEV_DEPS="git make cmake zoslib zip zedc_ascii"

export ZOPEN_CONFIGURE="skip"
export ZOPEN_MAKE_OPTS="-f unix/Makefile generic"
export ZOPEN_INSTALL_OPTS="-f unix/Makefile install prefix=\$ZOPEN_INSTALL_DIR/"
export ZOPEN_CHECK="${PWD}/unzip-tests/tests.sh"
export ZOPEN_COMP=CLANG
export ZOPEN_EXTRA_CFLAGS="-DUSE_ZLIB -DNO_ZLIBCALLBCK"

zopen_pre_patch() {
  export CFLAGS_EXTRA="$CPPFLAGS $CFLAGS"
  export LDFLAGS_EXTRA="$LDFLAGS"
  export LIBS_EXTRA="$LIBS"
}

zopen_post_extract() {
  DEBIAN_URL="https://deb.debian.org/debian/pool/main/u/unzip/unzip_${UNZIP_VERSION}-${DEBIAN_VERSION}.debian.tar.xz"

  echo "Downloading Debian patches from ${DEBIAN_URL}..."
  curl -L -o debian_patches.tar.xz ${DEBIAN_URL}
  tar -xJf debian_patches.tar.xz

  src_dir="$1"
  original_dir=$(pwd)
  debian_dir="${original_dir}/debian"

  cd "${src_dir}" || return 1

  # Apply Debian patches in the correct order from the series file
  if [ -f "${debian_dir}/patches/series" ]; then
    while read -r p; do
      # Skip empty lines and comments
      case "$p" in
        ""|'#'*) continue ;;
      esac

      # Apply if the patch exists (allows for manual skipping if needed)
      if [ -f "${debian_dir}/patches/$p" ]; then
        echo "Applying ${debian_dir}/patches/$p..."
        patch -p1 < "${debian_dir}/patches/$p" || return 1
      fi
    done < "${debian_dir}/patches/series"
  fi

  cd "${original_dir}"
  rm -rf "${debian_dir}" debian_patches.tar.xz
}

zopen_check_results()
{
  chk="$1/$2_check.log"
  totalTests=$(egrep "^Total tests:" $chk | awk '{ print $3}')
  failures=$(egrep "^Failed:" $chk | awk '{ print $2}')

# Echo the following information to guage build health
cat <<TEST
actualFailures:$failures
totalTests:$totalTests
expectedFailures:2
TEST
}

